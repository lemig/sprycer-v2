# Sprycer v2 environment.
# Copy to .env, fill in values. .env is gitignored.

# Django
SECRET_KEY=replace-with-a-random-50-char-string
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres (local dev). For Neon: paste the pooled connection string fields here.
POSTGRES_DB=sprycer
POSTGRES_USER=sprycer
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSLMODE=prefer

# OpenAI (used by H11+ embedding + matching pipeline)
OPENAI_API_KEY=

# Local file storage. In Fly.io, mount a volume here.
MEDIA_ROOT=./media
