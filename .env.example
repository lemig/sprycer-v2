# Sprycer v2 environment.
# Copy to .env, fill in values. .env is gitignored.

# Django
SECRET_KEY=replace-with-a-random-50-char-string
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres
#
# Local dev (Docker):
#   docker run --name sprycer-pg -e POSTGRES_PASSWORD=x -p 5432:5432 \
#     -d pgvector/pgvector:pg16
#   POSTGRES_HOST=localhost  POSTGRES_USER=postgres  POSTGRES_PASSWORD=x  POSTGRES_SSLMODE=disable
#
# Neon (production / staging):
#   1. neon.tech → New Project → name "sprycer", region eu-central-1
#   2. Project dashboard → Connection Details → "Direct connection" (NOT "Pooled")
#      [Pooled has psycopg3 prepared-statement quirks — use direct for now;
#       tune in a follow-up if connection count becomes a concern.]
#   3. Split the postgres://USER:PASS@HOST/DB?sslmode=require into the fields below
#   POSTGRES_SSLMODE=require
POSTGRES_DB=sprycer
POSTGRES_USER=sprycer
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSLMODE=prefer

# OpenAI (used by H11+ embedding + matching pipeline)
OPENAI_API_KEY=

# Local file storage. In Fly.io, mount a volume here.
MEDIA_ROOT=./media
